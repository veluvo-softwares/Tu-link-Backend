# Tu-Link Backend Environment Configuration
# Copy this file to .env and fill in your values

# Application Settings
NODE_ENV=development
PORT=3000

# Firebase Configuration (Required for auth)
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=your-client-email@your-project-id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----"
FIREBASE_DATABASE_URL=https://your-project-id.firebaseio.com
FIREBASE_API_KEY=your_firebase_api_key

# External APIs
GOOGLE_MAPS_API_KEY=your-google-maps-api-key
MAPBOX_ACCESS_TOKEN=your-mapbox-access-token

# Database
REDIS_HOST=localhost
REDIS_PORT=6379
# REQUIRED: Redis now enforces authentication (--requirepass). Set a strong,
# random value (e.g. `openssl rand -base64 32`). The same value is used by both
# the Redis server and the app, so they must match.
REDIS_PASSWORD=

# Security
JWT_SECRET=your-super-secret-jwt-key-at-least-32-characters

# CORS (for frontend)
CORS_ORIGIN=http://localhost:3000,http://localhost:3001

# Firebase Realtime Database
FIREBASE_DATABASE_URL=https://your-project-id-default-rtdb.firebaseio.com

# RTDB cleanup delay after journey ends (ms)
RTDB_CLEANUP_DELAY_MS=5000

# Email Configuration (for email verification & notifications)
RESEND_API_KEY=re_your_api_key_here
RESEND_FROM_EMAIL=TuLink <noreply@tulink.xyz>



# --- Postgres / PostGIS ---
POSTGRES_USER=tulink
POSTGRES_PASSWORD=your-strong-postgres-password
POSTGRES_DB=tulink
POSTGRES_HOST=localhost     # app overrides to `postgres` inside Docker (set in compose)
POSTGRES_PORT=5432
POSTGRES_POOL_MAX=10
# Used by drizzle-kit, which runs from the HOST -> localhost
DATABASE_URL=postgresql://tulink:your-strong-postgres-password@localhost:5432/tulink
